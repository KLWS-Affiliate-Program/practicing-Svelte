{
  "version": "0.2.0",
  "configurations": [

    // ── 1. Django Dev Server ─────────────────────────────────────────────────
    {
      "name": "🚀 Django Dev Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["runserver", "--noreload"],
      "django": true,
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.local"
      },
      "console": "integratedTerminal"
    },

    // ── 2. Run All Tests ─────────────────────────────────────────────────────
    {
      "name": "🧪 Run All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.test"
      },
      "console": "integratedTerminal"
    },

    // ── 3. Debug Current Test File ───────────────────────────────────────────
    {
      "name": "🔍 Debug Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v", "-s"],
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.test"
      },
      "console": "integratedTerminal"
    },

    // ── 4. Celery Worker ─────────────────────────────────────────────────────
    {
      "name": "⚙️ Celery Worker",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A", "config",
        "worker",
        "--loglevel=info",
        "--concurrency=1"
      ],
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.local"
      },
      "console": "integratedTerminal"
    },

    // ── 5. Django Shell ──────────────────────────────────────────────────────
    {
      "name": "🐚 Django Shell",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["shell"],
      "django": true,
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.local"
      },
      "console": "integratedTerminal"
    },

    // ── 6. Make Migrations ───────────────────────────────────────────────────
    {
      "name": "📦 Make Migrations",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["makemigrations"],
      "django": true,
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.local"
      },
      "console": "integratedTerminal"
    }

  ]
}
